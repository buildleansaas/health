{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "routine.schema.json",
  "title": "Routine",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "difficulty", "equipment", "rounds", "estimated_duration_minutes", "exercises"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
    "equipment": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rounds": { "type": "integer", "minimum": 1 },
    "estimated_duration_minutes": { "type": "integer", "minimum": 1 },
    "exercises": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["exercise_id", "name", "work_seconds", "rest_seconds"],
        "properties": {
          "exercise_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "work_seconds": { "type": "integer", "minimum": 5 },
          "rest_seconds": { "type": "integer", "minimum": 5 }
        }
      }
    }
  }
}
