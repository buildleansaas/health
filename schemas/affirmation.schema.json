{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "affirmation.schema.json",
  "title": "Affirmation",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "text"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "text": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
